APP_ENV=development
APP_NAME=tiku-zong-api
HTTP_ADDR=:8088
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/tiku_zong?charset=utf8mb4&parseTime=True&loc=UTC
REDIS_ADDR=127.0.0.1:6379
JWT_SECRET=replace-with-a-long-random-secret
DATA_ENCRYPTION_SECRET=replace-with-a-separate-encryption-secret
PUBLIC_BASE_URL=http://localhost:8088
API_RATE_LIMIT_PER_MINUTE=120
IP_BLACKLIST=
IP_WHITELIST=
ADMIN_TOTP_SECRET=
ANSWER_MERGE_RULE=priority
